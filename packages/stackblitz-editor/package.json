{
  "name": "@x-ude/adapter-stackblitz-editor",
  "version": "0.0.0",
  "description": "StackBlitz-backed editor adapter for the x-ude engine.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings=0",
    "test": "vitest run"
  },
  "dependencies": {
    "@stackblitz/sdk": "^1.11.0"
  },
  "peerDependencies": {
    "@x-ude/sdk": "workspace:*"
  },
  "devDependencies": {
    "@x-ude/sdk": "workspace:*",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "vitest": "^1.4.0"
  }
}
